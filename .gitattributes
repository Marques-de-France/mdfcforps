# Files excluded from the distributable ZIP built by `git archive`
# (used by .github/workflows/release.yml). vendor/ and composer.lock are
# untracked, so they are already excluded from the archive.
/.gitattributes    export-ignore
/.gitignore        export-ignore
/.github           export-ignore
/tests             export-ignore
/phpunit.xml.dist  export-ignore
/.php_cs.dist      export-ignore
