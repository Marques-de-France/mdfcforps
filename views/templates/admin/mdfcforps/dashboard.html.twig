{% extends '@PrestaShop/Admin/layout.html.twig' %}
{% trans_default_domain 'Modules.Mdfcforps.Admin' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('../modules/mdfcforps/views/css/admin.css') }}&mdf=20260612">
{% endblock %}

{% block content %}
<div class="mdf-admin-wrap">
  {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_navigation_tabs.html.twig', { currentTab: currentTab|default('dashboard') }) }}

  <div class="tab-content">
    {% if error %}
      <div class="alert alert-danger" role="alert">
        {{ error }}
      </div>
    {% else %}
      {% if status.connected|default(false) %}
        <div class="alert alert-success" role="alert">
          <p class="alert-text">{{ 'Connected'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
        </div>
      {% else %}
        <div class="alert alert-danger" role="alert">
          <p class="alert-text">{{ 'Unable to connect to Marques de France. Please contact support at support@marques-de-france.fr.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
        </div>
      {% endif %}

      <div class="mdf-sales-kpis mb-4">
        {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_kpi_card.html.twig', {
          label: 'Total Sales'|trans({}, 'Modules.Mdfcforps.Admin'),
          value: dashboardStats.totalSales|default('0'),
          subLabel: 'All time'|trans({}, 'Modules.Mdfcforps.Admin')
        }, with_context = false) }}
        {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_kpi_card.html.twig', {
          label: 'Total Revenue'|trans({}, 'Modules.Mdfcforps.Admin'),
          value: dashboardStats.totalRevenue is defined ? dashboardStats.totalRevenue|number_format(2, '.', ' ') ~ ' €' : '0.00 €',
          subLabel: 'Confirmed'|trans({}, 'Modules.Mdfcforps.Admin')
        }, with_context = false) }}
        {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_kpi_card.html.twig', {
          label: 'This Month'|trans({}, 'Modules.Mdfcforps.Admin'),
          value: dashboardStats.monthRevenue is defined ? dashboardStats.monthRevenue|number_format(2, '.', ' ') ~ ' €' : '0.00 €',
          subLabel: (dashboardStats.monthSales|default(0)) ~ ' ' ~ ((dashboardStats.monthSales|default(0)) == 1 ? 'sale'|trans({}, 'Modules.Mdfcforps.Admin') : 'sales'|trans({}, 'Modules.Mdfcforps.Admin'))
        }, with_context = false) }}
      </div>

      {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_revenue_chart.html.twig', {
        chartTitle: 'Sales over the last 12 months'|trans({}, 'Modules.Mdfcforps.Admin'),
        showControls: false,
        canvasId: 'mdf-dashboard-revenue-chart',
        tooltipId: 'mdf-dashboard-chart-tooltip',
        emptyId: 'mdf-dashboard-chart-empty'
      }, with_context = false) }}
    {% endif %}
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    window.mdfcforpsRevenueCharts = window.mdfcforpsRevenueCharts || [];
    window.mdfcforpsRevenueCharts.push({
      analytics: {{ dashboardAnalytics|default({})|json_encode|raw }},
      currency: '{{ dashboardAnalytics.currency|default('EUR') }}',
      revenueLabel: '{{ 'Revenue'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}',
      salesLabel: '{{ 'Sales'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}',
      emptyLabel: '{{ 'No data for the selected period.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}',
      canvasId: 'mdf-dashboard-revenue-chart',
      tooltipId: 'mdf-dashboard-chart-tooltip',
      emptyId: 'mdf-dashboard-chart-empty',
      defaultRange: '12m',
      defaultGranularity: 'month'
    });
  </script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.5.0/chart.umd.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script src="{{ asset('../modules/mdfcforps/views/js/admin/revenue-chart.js') }}&mdf=20260612-1"></script>
{% endblock %}
