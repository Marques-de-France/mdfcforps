{#**
 * Marques de France — BO Admin — Product Feed tab (Symfony / Grid component)
 *#}
{% extends '@PrestaShop/Admin/layout.html.twig' %}
{% trans_default_domain 'Modules.Mdfcforps.Admin' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('../modules/mdfcforps/views/css/admin.css') }}&mdf=20260612">
{% endblock %}

{% block content %}
<div class="mdf-admin-wrap">

  {# ---- Tab navigation ---- #}
  {{ include('@Modules/mdfcforps/views/templates/admin/mdfcforps/_navigation_tabs.html.twig', { currentTab: currentTab|default('feed') }) }}

  <div class="tab-content">
    {% if feedError is defined and feedError %}
      <div class="alert alert-danger" role="alert">
        {{ feedError }}
      </div>
    {% endif %}

    {# ---- Feed mode toggle ---- #}
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="d-inline-block card-header-title mb-0">{{ 'Selection method'|trans({}, 'Modules.Mdfcforps.Admin') }}</h3>
      </div>
      <div class="card-body">
        <p class="mb-3" id="mdf-feed-mode-current-value">
          {% if feedMode == 'SERVERLIST' %}
            {{ 'Via manual selection from this module'|trans({}, 'Modules.Mdfcforps.Admin') }}
          {% else %}
            {{ 'Via the product tag field'|trans({}, 'Modules.Mdfcforps.Admin') }}
          {% endif %}
        </p>
        <button type="button" class="btn btn-primary" id="mdf-feed-mode-change-btn" data-toggle="modal" data-target="#mdf-feed-mode-modal" onclick="if (window.mdfOpenFeedModeModal) { window.mdfOpenFeedModeModal(); } return false;">
          {{ 'Change'|trans({}, 'Modules.Mdfcforps.Admin') }}
        </button>
      </div>
    </div>

    <div class="modal fade" id="mdf-feed-mode-modal" tabindex="-1" role="dialog" aria-labelledby="mdf-feed-mode-modal-label" aria-hidden="true">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <form method="post" action="{{ path('mdfcforps_feed_mode') }}" id="mdf-feed-mode-modal-form">
            <input type="hidden" name="_token" value="{{ feedCsrfToken|default('') }}">
            <div class="modal-header">
              <h5 class="modal-title" id="mdf-feed-mode-modal-label">{{ 'Change mode'|trans({}, 'Modules.Mdfcforps.Admin') }}</h5>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="if (window.mdfCloseFeedModeModal) { window.mdfCloseFeedModeModal(); } return false;">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label for="mdf-feed-mode-select">{{ 'Selection method'|trans({}, 'Modules.Mdfcforps.Admin') }}</label>
                <select class="form-control" id="mdf-feed-mode-select" name="feed_mode">
                  <option value="TAG" {% if feedMode == 'TAG' %}selected{% endif %}>{{ 'Via the product tag field (Recommended)'|trans({}, 'Modules.Mdfcforps.Admin') }}</option>
                  <option value="SERVERLIST" {% if feedMode == 'SERVERLIST' %}selected{% endif %}>{{ 'Via manual selection from this module'|trans({}, 'Modules.Mdfcforps.Admin') }}</option>
                </select>
              </div>

              <hr>

              <p class="mb-4"><strong>{{ 'Via the product tag field (recommended)'|trans({}, 'Modules.Mdfcforps.Admin') }}</strong><br>{{ 'Simply add the tag'|trans({}, 'Modules.Mdfcforps.Admin') }} <span class="badge badge-secondary">marques-de-france</span> {{ 'to each of your products manufactured in France (in the "SEO" tab when editing a product). This is the simplest and most direct method.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
              <p class="mb-0"><strong>{{ 'Via manual selection from this module'|trans({}, 'Modules.Mdfcforps.Admin') }}</strong><br>{{ 'Manually select products directly from this app. Choose this option if your product tag field is used to display information in your theme.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
            </div>
            <div class="modal-footer">
              <button type="submit" class="btn btn-primary">{{ 'Save'|trans({}, 'Admin.Actions') }}</button>
              <button type="button" class="btn btn-outline-secondary" data-dismiss="modal" onclick="if (window.mdfCloseFeedModeModal) { window.mdfCloseFeedModeModal(); } return false;">{{ 'Cancel'|trans({}, 'Admin.Actions') }}</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    {# ---- SERVERLIST product management ---- #}
    {% if feedMode == 'SERVERLIST' %}
      <div class="mdf-serverlist-panel">

        {# ---- Manage panel (catalog grid) ---- #}
        {% if manage and productCatalogGrid is defined %}
          <div class="card mb-4" id="mdf-manage-panel">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h3 class="d-inline-block card-header-title mb-0">{{ 'Select products to include in feed'|trans({}, 'Modules.Mdfcforps.Admin') }}</h3>
              <div class="d-flex align-items-center gap-2">
                <a href="{{ path('mdfcforps_feed_index') }}" class="btn btn-outline-secondary mr-2">
                  {{ 'Back'|trans({}, 'Admin.Actions') }}
                </a>
                <a href="{{ path('mdfcforps_feed_index') }}" class="btn btn-primary">
                  {{ 'Save'|trans({}, 'Admin.Actions') }}
                </a>
              </div>
            </div>
            <div class="card-body">
              <div class="alert alert-warning" role="alert">
                {{ 'Only select products manufactured in France. These are the products that will appear in the Marques de France guide.'|trans({}, 'Modules.Mdfcforps.Admin') }}
              </div>
              {{ include('@PrestaShop/Admin/Common/Grid/grid.html.twig', {'grid': productCatalogGrid}) }}
              <div class="p-3">
                <a href="{{ path('mdfcforps_feed_index') }}" class="btn btn-primary">
                  {{ 'Save'|trans({}, 'Admin.Actions') }}
                </a>
              </div>
            </div>
          </div>
        {% endif %}

        {# ---- Products in feed grid (hidden in manage mode) ---- #}
        {% if not manage %}
          <div class="alert alert-info" role="alert">
            {{ 'Out-of-stock, inactive, or products missing a price, image, or brand are automatically excluded from the feed.'|trans({}, 'Modules.Mdfcforps.Admin') }}
          </div>
          <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h3 class="d-inline-block card-header-title mb-0">{{ 'Products in feed'|trans({}, 'Modules.Mdfcforps.Admin') }}</h3>
              <a href="{{ path('mdfcforps_feed_index', {manage: 1}) }}" class="btn btn-primary">
                {{ 'Manage products'|trans({}, 'Modules.Mdfcforps.Admin') }}
              </a>
            </div>
            <div class="card-body">
              {% if productFeedGrid is defined and productFeedGrid %}
                {{ include('@PrestaShop/Admin/Common/Grid/grid.html.twig', {'grid': productFeedGrid}) }}
              {% endif %}
            </div>
          </div>
        {% endif %}

      </div>
    {% else %}
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="d-inline-block card-header-title mb-0">{{ 'How to include products in the feed?'|trans({}, 'Modules.Mdfcforps.Admin') }}</h3>
        </div>
        <div class="card-body">
          <p class="mb-3">{{ 'Add the tag'|trans({}, 'Modules.Mdfcforps.Admin') }} <span class="badge badge-secondary">marques-de-france</span> {{ 'to the products you want to list on Marques de France. Selected products must be manufactured in France.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
          <div class="d-flex align-items-center flex-wrap">
            <a href="{{ getAdminLink('AdminTags', true) }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary mr-3 mb-2">
              {{ 'Add tag in bulk'|trans({}, 'Modules.Mdfcforps.Admin') }}
            </a>
            <button type="button" class="btn btn-link p-0 mb-2" id="mdf-tag-help-open-btn" data-toggle="modal" data-target="#mdf-tag-help-modal" onclick="if (window.mdfOpenTagHelpModal) { window.mdfOpenTagHelpModal(); } return false;">
              {{ 'How to do?'|trans({}, 'Modules.Mdfcforps.Admin') }}
            </button>
          </div>
        </div>
      </div>

      <div class="modal fade" id="mdf-tag-help-modal" tabindex="-1" role="dialog" aria-labelledby="mdf-tag-help-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="mdf-tag-help-modal-label">{{ 'How to add the marques-de-france tag?'|trans({}, 'Modules.Mdfcforps.Admin') }}</h5>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="if (window.mdfCloseTagHelpModal) { window.mdfCloseTagHelpModal(); } return false;">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body">
              <div class="mb-4">
                <div class="d-flex mb-3">
                  <div class="mr-3 text-center" style="min-width: 24px;">
                    <span class="badge badge-primary rounded-circle" style="width: 28px; height: 28px; line-height: 20px; font-size:16px;">1</span>
                  </div>
                  <div>
                    <p class="font-weight-bold mb-1">{{ 'Go to Products'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                    <p class="text-muted mb-0">{{ 'From your PrestaShop admin, go to Catalog > Products.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                  </div>
                </div>

                <div class="d-flex mb-3">
                  <div class="mr-3 text-center" style="min-width: 24px;">
                    <span class="badge badge-primary rounded-circle" style="width: 28px; height: 28px; line-height: 20px; font-size:16px;">2</span>
                  </div>
                  <div>
                    <p class="font-weight-bold mb-1">{{ 'Select a product'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                    <p class="text-muted mb-0">{{ 'Open a product made in France.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                  </div>
                </div>

                <div class="d-flex mb-3">
                  <div class="mr-3 text-center" style="min-width: 24px;">
                    <span class="badge badge-primary rounded-circle" style="width: 28px; height: 28px; line-height: 20px; font-size:16px;">3</span>
                  </div>
                  <div>
                    <p class="font-weight-bold mb-1">{{ 'Add the tag'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                    <p class="text-muted mb-0">{{ 'In the product page, go to the "SEO" tab and add the tag'|trans({}, 'Modules.Mdfcforps.Admin') }} <span class="badge badge-secondary">marques-de-france</span> {{ 'in the Tags field.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                  </div>
                </div>

                <div class="d-flex">
                  <div class="mr-3 text-center" style="min-width: 24px;">
                    <span class="badge badge-primary rounded-circle" style="width: 28px; height: 28px; line-height: 20px; font-size:16px;">4</span>
                  </div>
                  <div>
                    <p class="font-weight-bold mb-1">{{ 'Save'|trans({}, 'Admin.Actions') }}</p>
                    <p class="text-muted mb-0">{{ 'Click Save and publish. The product will appear in the feed.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
                  </div>
                </div>
              </div>

              <hr>

              <p class="font-weight-bold mb-2">{{ 'How to bulk edit?'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
              {% set adminTagsUrl = getAdminLink('AdminTags', true) %}
              {% set adminTagsLabel = 'Shop parameters > Search > Tags'|trans({}, 'Modules.Mdfcforps.Admin') %}
              {% set adminTagsLink = '<a href="' ~ adminTagsUrl ~ '" target="_blank" rel="noopener noreferrer">' ~ adminTagsLabel ~ '</a>' %}
              <p class="text-muted mb-3">{{ 'To add the tag to multiple products at once, go to %tags_link%. Then, create or edit the'|trans({'%tags_link%': adminTagsLink}, 'Modules.Mdfcforps.Admin')|raw }} <span class="badge badge-secondary">marques-de-france</span> {{ 'tag by adding products to it.'|trans({}, 'Modules.Mdfcforps.Admin') }}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="alert alert-info" role="alert">
        {{ 'Out-of-stock, inactive, or products missing a price, image, or brand are automatically excluded from the feed.'|trans({}, 'Modules.Mdfcforps.Admin') }}
      </div>
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h3 class="d-inline-block card-header-title mb-0">{{ 'Products in feed'|trans({}, 'Modules.Mdfcforps.Admin') }}</h3>
        </div>
        <div class="card-body">
          {% if productFeedGrid is defined and productFeedGrid %}
            {{ include('@PrestaShop/Admin/Common/Grid/grid.html.twig', {'grid': productFeedGrid}) }}
          {% endif %}
        </div>
      </div>
    {% endif %}

  </div>{# /.tab-content #}
</div>{# /.mdf-admin-wrap #}

{# ---- AJAX config for feed.js ---- #}
<script>
window.mdfcforpsFeed = {
  toggleUrl: "{{ path('mdfcforps_feed_toggle') }}",
  bulkUrl:   "{{ path('mdfcforps_feed_bulk') }}",
  csrfToken: "{{ feedCsrfToken|default('')|e('js') }}",
  i18n: {
    selectDeselectAllVisible: "{{ 'Select / deselect all visible'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    errorLoadingProducts: "{{ 'Error loading products.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    noProductsFound: "{{ 'No products found.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    noProductsInCatalog: "{{ 'No products in your catalog.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    productsCount: "{{ '{count} product(s)'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    pageSummary: "{{ 'Page {page} of {total} - {count} products'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    confirmRemoveProduct: "{{ 'Remove this product from the feed?'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    errorRemovingProduct: "{{ 'Error removing product.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}",
    networkErrorRetry: "{{ 'Network error. Please try again.'|trans({}, 'Modules.Mdfcforps.Admin')|e('js') }}"
  }
};

(function () {
  function initFeedModeModal() {
    var changeBtn = document.getElementById('mdf-feed-mode-change-btn');
    var modal = document.getElementById('mdf-feed-mode-modal');
    if (!changeBtn || !modal) {
      return;
    }

    function openModal() {
      if (typeof window.$ === 'function' && window.$.fn && typeof window.$.fn.modal === 'function') {
        window.$(modal).modal('show');
        if (modal.classList.contains('show') || modal.style.display === 'block') {
          return;
        }
      }

      modal.classList.add('show');
      modal.style.display = 'block';
      modal.removeAttribute('aria-hidden');
      document.body.classList.add('modal-open');
      document.body.style.paddingRight = '0px';

      if (!document.querySelector('.modal-backdrop')) {
        var backdrop = document.createElement('div');
        backdrop.className = 'modal-backdrop fade show';
        backdrop.setAttribute('data-mdf-fallback-backdrop', '1');
        backdrop.addEventListener('click', closeModal);
        document.body.appendChild(backdrop);
      }
    }

    function closeModal() {
      if (typeof window.$ === 'function' && window.$.fn && typeof window.$.fn.modal === 'function') {
        window.$(modal).modal('hide');
        if (!modal.classList.contains('show') && modal.style.display !== 'block') {
          return;
        }
      }

      modal.classList.remove('show');
      modal.style.display = 'none';
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('modal-open');
      document.body.style.paddingRight = '';

      var backdrop = document.querySelector('.modal-backdrop[data-mdf-fallback-backdrop="1"]');
      if (backdrop) {
        backdrop.remove();
      }
    }

    changeBtn.addEventListener('click', function () {
      openModal();
    });

    window.mdfOpenFeedModeModal = openModal;
    window.mdfCloseFeedModeModal = closeModal;

    modal.querySelectorAll('[data-dismiss="modal"]').forEach(function (button) {
      button.addEventListener('click', function () {
        closeModal();
      });
    });
  }

  function initTagHelpModal() {
    var openBtn = document.getElementById('mdf-tag-help-open-btn');
    var modal = document.getElementById('mdf-tag-help-modal');
    if (!openBtn || !modal) {
      return;
    }

    function openModal() {
      if (typeof window.$ === 'function' && window.$.fn && typeof window.$.fn.modal === 'function') {
        window.$(modal).modal('show');
        if (modal.classList.contains('show') || modal.style.display === 'block') {
          return;
        }
      }

      modal.classList.add('show');
      modal.style.display = 'block';
      modal.removeAttribute('aria-hidden');
      document.body.classList.add('modal-open');
      document.body.style.paddingRight = '0px';

      if (!document.querySelector('.modal-backdrop')) {
        var backdrop = document.createElement('div');
        backdrop.className = 'modal-backdrop fade show';
        backdrop.setAttribute('data-mdf-fallback-backdrop', '1');
        backdrop.addEventListener('click', closeModal);
        document.body.appendChild(backdrop);
      }
    }

    function closeModal() {
      if (typeof window.$ === 'function' && window.$.fn && typeof window.$.fn.modal === 'function') {
        window.$(modal).modal('hide');
        if (!modal.classList.contains('show') && modal.style.display !== 'block') {
          return;
        }
      }

      modal.classList.remove('show');
      modal.style.display = 'none';
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('modal-open');
      document.body.style.paddingRight = '';

      var backdrop = document.querySelector('.modal-backdrop[data-mdf-fallback-backdrop="1"]');
      if (backdrop) {
        backdrop.remove();
      }
    }

    openBtn.addEventListener('click', function () {
      openModal();
    });

    window.mdfOpenTagHelpModal = openModal;
    window.mdfCloseTagHelpModal = closeModal;

    modal.querySelectorAll('[data-dismiss="modal"]').forEach(function (button) {
      button.addEventListener('click', function () {
        closeModal();
      });
    });
  }

  function preserveManageMode(gridId, panel) {
    var currentUrl = new URL(window.location.href);
    var isManageMode = currentUrl.searchParams.get('manage') === '1';
    if (!isManageMode || !panel) {
      return;
    }

    var filterForm = document.getElementById(gridId + '_filter_form');
    if (filterForm) {
      var hiddenManage = filterForm.querySelector('input[name="manage"]');
      if (!hiddenManage) {
        hiddenManage = document.createElement('input');
        hiddenManage.type = 'hidden';
        hiddenManage.name = 'manage';
        hiddenManage.value = '1';
        filterForm.appendChild(hiddenManage);
      }

      if (filterForm.action) {
        var actionUrl = new URL(filterForm.action, window.location.origin);
        actionUrl.searchParams.set('manage', '1');
        filterForm.action = actionUrl.toString();
      }
    }

    panel.querySelectorAll('a[href]').forEach(function (anchor) {
      var href = anchor.getAttribute('href');
      if (!href || href.indexOf('javascript:') === 0 || href.indexOf('#') === 0) {
        return;
      }

      var linkUrl = new URL(href, window.location.origin);
      if (linkUrl.origin !== window.location.origin || linkUrl.pathname !== window.location.pathname) {
        return;
      }

      linkUrl.searchParams.set('manage', '1');
      anchor.setAttribute('href', linkUrl.toString());
    });
  }

  // Collect the manage-grid row checkboxes. Scoped by class only (not by a grid
  // wrapper id) so it works regardless of how PS 1.7 / 8 / 9 nest the grid table.
  function getManageCheckboxes() {
    return Array.prototype.slice.call(document.querySelectorAll('.mdf-manage-cb'));
  }

  function updateManageSelectAllState() {
    var selectAll = document.getElementById('mdf-manage-select-all');
    if (!selectAll) {
      return;
    }

    var all = getManageCheckboxes();
    var checked = all.filter(function (cb) { return cb.checked; });
    selectAll.checked = all.length > 0 && checked.length === all.length;
    selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
  }

  function ensureManageSelectAll() {
    var currentUrl = new URL(window.location.href);
    if (currentUrl.searchParams.get('manage') !== '1') {
      return;
    }

    // Locate the manage table via an actual row checkbox rather than a grid id,
    // since the grid wrapper markup differs across PrestaShop versions.
    var firstCheckbox = document.querySelector('.mdf-manage-cb');
    if (!firstCheckbox) {
      return;
    }

    var table = firstCheckbox.closest('table');
    var firstHeader = table ? table.querySelector('thead th:first-child') : null;
    if (!firstHeader || firstHeader.querySelector('#mdf-manage-select-all')) {
      return;
    }

    var i18n = window.mdfcforpsFeed && window.mdfcforpsFeed.i18n ? window.mdfcforpsFeed.i18n : {};
    firstHeader.innerHTML = '<div class="md-checkbox md-checkbox-inline"><label><input type="checkbox" id="mdf-manage-select-all" class="form-check-input" title="' + (i18n.selectDeselectAllVisible || 'Select / deselect all visible') + '"><i class="md-checkbox-control"></i></label></div>';
    updateManageSelectAllState();
  }

  function toggleSelectAll(checked) {
    var checkboxes = getManageCheckboxes();
    var toAdd = [];
    var toRemove = [];

    checkboxes.forEach(function (checkbox) {
      var row = checkbox.closest('tr');
      var pid = checkbox.getAttribute('data-product-id') || (row && row.getAttribute('data-product-id'));
      var inFeed = (checkbox.getAttribute('data-in-feed') || (row && row.getAttribute('data-in-feed'))) === '1';
      if (!pid) {
        return;
      }

      if (checked && !inFeed) {
        toAdd.push(pid);
      }
      if (!checked && inFeed) {
        toRemove.push(pid);
      }
    });

    function postBulk(action, ids) {
      if (!ids.length) {
        return Promise.resolve();
      }

      var config = window.mdfcforpsFeed;
      var url = config && config.bulkUrl ? config.bulkUrl : '';
      var form = new FormData();
      form.append('action', action);
      ids.forEach(function (id) {
        form.append('product_ids[]', id);
      });
      // Module CSRF token — bulkAction() rejects the request (403) without it.
      if (config && config.csrfToken) {
        form.append('_token', config.csrfToken);
      }

      return fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        body: form,
      })
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (!json.success) {
          return;
        }

        ids.forEach(function (pid) {
          var rowCb = document.querySelector('.mdf-manage-cb[data-product-id="' + pid + '"]');
          if (!rowCb) {
            return;
          }

          var row = rowCb.closest('tr');
          var next = action === 'add';
          if (row) {
            row.setAttribute('data-in-feed', next ? '1' : '0');
          }
          rowCb.checked = next;
          rowCb.setAttribute('data-in-feed', next ? '1' : '0');
        });

        updateManageSelectAllState();
      });
    }

    Promise.all([
      postBulk('add', toAdd),
      postBulk('remove', toRemove),
    ]);
  }

  function initGrid(gridId) {
    if (!window.prestashop || !window.prestashop.component) {
      return;
    }

    var components = window.prestashop.component;
    var extensions = components.GridExtensions;
    var panel = document.getElementById(gridId + '_grid_panel') || document.getElementById(gridId + '_grid');

    if (!panel || !components.Grid || !extensions) {
      return;
    }

    var grid = new components.Grid(gridId);
    preserveManageMode(gridId, panel);
    if (gridId === 'product_catalog') {
      ensureManageSelectAll();
      // The grid table is re-rendered on AJAX sort/filter/paginate, which wipes the
      // injected header checkbox — re-inject it whenever the panel content changes.
      if (window.MutationObserver) {
        new MutationObserver(function () {
          ensureManageSelectAll();
        }).observe(panel, { childList: true, subtree: true });
      }
    }

    // Enable core Grid behavior (sorting, filter submit/reset, pagination actions).
    grid.addExtension(new extensions.SortingExtension());
    grid.addExtension(new extensions.SubmitGridActionExtension());
    grid.addExtension(new extensions.FiltersResetExtension());
    grid.addExtension(new extensions.FiltersSubmitButtonEnablerExtension());
    grid.addExtension(new extensions.ReloadListExtension());

    // Fallback: submit filter form on Enter in text inputs.
    var filterForm = document.getElementById(gridId + '_filter_form');
    if (filterForm) {
      filterForm.addEventListener('keydown', function (event) {
        var target = event.target;
        if (event.key !== 'Enter' || !target || target.tagName !== 'INPUT') {
          return;
        }

        event.preventDefault();
        if (typeof filterForm.requestSubmit === 'function') {
          filterForm.requestSubmit();
        } else {
          filterForm.submit();
        }
      });

      filterForm.addEventListener('change', function (event) {
        var target = event.target;
        if (!target || target.tagName !== 'SELECT') {
          return;
        }

        if (typeof filterForm.requestSubmit === 'function') {
          filterForm.requestSubmit();
        } else {
          filterForm.submit();
        }
      });
    }

    // Fallback: paginator page-size selector to query params for this grid.
    panel.addEventListener('change', function (event) {
      var target = event.target;
      if (!target || target.name !== 'paginator_select_page_limit') {
        return;
      }

      var url = new URL(window.location.href);
      url.searchParams.set(gridId + '[limit]', target.value);
      url.searchParams.set(gridId + '[offset]', '0');
      window.location.href = url.toString();
    });

    panel.addEventListener('click', function (event) {
      var currentUrl = new URL(window.location.href);
      if (currentUrl.searchParams.get('manage') !== '1') {
        return;
      }

      var anchor = event.target.closest('a[href]');
      if (!anchor) {
        return;
      }

      var href = anchor.getAttribute('href');
      if (!href || href.indexOf('#') === 0 || href.indexOf('javascript:') === 0) {
        return;
      }

      var linkUrl = new URL(href, window.location.origin);
      if (linkUrl.origin !== window.location.origin || linkUrl.pathname !== window.location.pathname) {
        return;
      }

      if (linkUrl.searchParams.get('manage') === '1') {
        return;
      }

      event.preventDefault();
      linkUrl.searchParams.set('manage', '1');
      window.location.href = linkUrl.toString();
    });
  }

  function initManageSelectAll() {
    if (window.__mdfManageSelectAllBound) {
      return;
    }
    window.__mdfManageSelectAllBound = true;

    // Document-level delegation so the select-all works regardless of grid DOM
    // nesting (PS 1.7 differs from 8/9) and survives grid re-renders.
    document.addEventListener('change', function (event) {
      var target = event.target;
      if (!target) {
        return;
      }
      if (target.id === 'mdf-manage-select-all') {
        toggleSelectAll(target.checked);
      } else if (target.classList && target.classList.contains('mdf-manage-cb')) {
        // Keep the header checkbox in sync when a single row is toggled.
        updateManageSelectAllState();
      }
    });
  }

  function boot(attempt) {
    attempt = attempt || 0;

    initFeedModeModal();
    initTagHelpModal();
    initManageSelectAll();

    // Parent scripts can be deferred; wait until PrestaShop components are ready.
    if (!window.prestashop || !window.prestashop.component || !window.prestashop.component.GridExtensions) {
      if (attempt < 200) {
        setTimeout(function () { boot(attempt + 1); }, 50);
      }
      return;
    }

    initGrid('product_feed');
    initGrid('product_catalog');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { boot(0); });
  } else {
    boot(0);
  }
})();
</script>
