{
    "name": "marquesdefrance/mdfcforps",
    "description": "Marques de France PrestaShop Connector",
    "type": "prestashop-module",
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^9.6",
        "prestashop/php-dev-tools": "^4.3"
    },
    "autoload": {
        "psr-4": {
            "Mdfcforps\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mdfcforps\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint:php": "find . -type f -name '*.php' ! -path './vendor/*' ! -path './tests/*' -exec php -l -n {} \\;",
        "lint:cs": "php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:phpstan": "php vendor/bin/phpstan analyse --configuration=tests/phpstan/phpstan.neon",
        "test": "php vendor/bin/phpunit --configuration=phpunit.xml.dist"
    },
    "config": {
        "prepend-autoloader": false
    }
}
